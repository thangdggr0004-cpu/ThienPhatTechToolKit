{
  "name": "thienphat-techtoolkit",
  "private": true,
  "version": "1.2.3",
  "description": "Thien Phat Tech Toolkit Pro",
  "type": "module",
  "main": "electron.cjs",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js dist-electron",
    "lint": "tsc --noEmit",
    "electron:dev": "concurrently -k \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "systeminformation": "^5.32.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^10.0.3",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.thienphat.techtoolkit",
    "productName": "ThienPhatTechToolkit",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron.cjs",
      "preload.cjs"
    ],
    "extraResources": [
      "elevate.exe"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "icon": "build/icon.png",
      "requestedExecutionLevel": "requireAdministrator",
      "certificateFile": "ThienPhatTech.pfx",
      "certificatePassword": "ThienPhat2026",
      "timeStampServer": "http://timestamp.digicert.com"
    },
    "publish": {
      "provider": "github",
      "owner": "thangdggr0004-cpu",
      "repo": "ThienPhatTechToolKit"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "portable": {
      "requestExecutionLevel": "admin"
    }
  }
}
